rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isVerified() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isVerified() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "carlos@dominus.site"
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             (!('role' in data) || (data.role in ['admin', 'user'])) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 256)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1024)) &&
             (!('customerName' in data) || (data.customerName is string && data.customerName.size() <= 256)) &&
             (!('customerEmail' in data) || (data.customerEmail is string && data.customerEmail.size() <= 256)) &&
             (!('customerPhone' in data) || (data.customerPhone is string && data.customerPhone.size() <= 32)) &&
             (!('customerTaxId' in data) || (data.customerTaxId is string && data.customerTaxId.size() <= 32)) &&
             (!('createdAt' in data) || (data.createdAt is string));
    }

    function isValidSale(data) {
      return data.keys().hasAll(['userId', 'packageId', 'amount', 'status']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.packageId is string && data.packageId.size() <= 128 &&
             data.amount is number &&
             data.status in ['pending', 'paid', 'expired'] &&
             (!('pixCode' in data) || (data.pixCode is string && data.pixCode.size() <= 1024)) &&
             (!('createdAt' in data) || (data.createdAt is string));
    }

    // 1. User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().uid == userId &&
                      incoming().role == 'user';
                      
      allow update: if isOwner(userId) && 
                      isValidId(userId) &&
                      isValidUser(incoming()) && 
                      incoming().role == existing().role && 
                      incoming().uid == existing().uid &&
                      incoming().email == existing().email &&
                      (!('createdAt' in existing()) || incoming().createdAt == existing().createdAt) &&
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'displayName', 'photoURL', 'customerName', 'customerEmail', 
                        'customerPhone', 'customerTaxId', 'createdAt'
                      ]);
                      
      allow update: if isAdmin() && isValidId(userId);
    }

    // 2. Sales Transactions
    match /sales/{saleId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isVerified() && 
                      isValidId(saleId) &&
                      incoming().userId == request.auth.uid &&
                      isValidSale(incoming()) &&
                      incoming().status == 'pending';
                      
      allow update: if isAdmin() && isValidId(saleId) && isValidSale(incoming());
    }

    // 3. Webhook Logs
    match /webhook_logs/{logId} {
      allow read, write: if isAdmin();
    }
    
    // 4. Admins collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
